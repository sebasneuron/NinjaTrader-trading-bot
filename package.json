{
  "name": "ninja-trade-bot",
  "version": "1.0.0",
  "description": "Semi-automated trading assistant for NinjaTrader via ATI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/api/public', 'dist/api/public', {recursive: true})\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:serve": "ts-node src/index.ts -- --serve",
    "dev:watch": "ts-node-dev --respawn src/index.ts",
    "serve": "node dist/index.js --serve",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ninjatrader",
    "trading",
    "ati",
    "signals",
    "futures"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
